<?xml version="1.0" encoding="UTF-8"?>
<includes>

	<variable name="darkpulse">
	    <value condition="String.IsEqual(Skin.String(PulseColor),Blue)">special://skin/extras/neropulse/blue_dark_pulse.png</value>
		<value condition="String.IsEqual(Skin.String(PulseColor),bronze)">special://skin/extras/neropulse/bronze_dark_pulse.png</value>
		<value condition="String.IsEqual(Skin.String(PulseColor),Green)">special://skin/extras/neropulse/green_dark_pulse.png</value>
		<value condition="String.IsEqual(Skin.String(PulseColor),Midnight)">special://skin/extras/neropulse/midnite_dark_pulse.png</value>
		<value condition="String.IsEqual(Skin.String(PulseColor),Cyan)">special://skin/extras/neropulse/cyan_dark_pulse.png</value>
		<value condition="String.IsEqual(Skin.String(PulseColor),Pink)">special://skin/extras/neropulse/pink_dark_pulse.png</value>
		<value condition="String.IsEqual(Skin.String(PulseColor),Red)">special://skin/extras/neropulse/red_dark_pulse.png</value>
		<value condition="String.IsEqual(Skin.String(PulseColor),Colors)">special://skin/extras/neropulse/bello_colors_pulse.png</value>
		<value>special://skin/extras/neropulse/blue_dark_pulse.png</value>
	</variable>
	<variable name="darkpulsediffuse">
		<value condition="String.IsEqual(Skin.String(PulseColor),Bello)">DD000000</value>
		<value condition="String.IsEqual(Skin.String(PulseColor),Pink)">99000000</value>
		<value>EE000000</value>
	</variable>
	<variable name="lightpulse">
		<value condition="String.IsEqual(Skin.String(PulseColor),Midnight)">special://skin/extras/neropulse/light_pulse_gray.png</value>
		<value condition="String.IsEqual(Skin.String(PulseColor),Blue) | String.IsEqual(Skin.String(PulseColor),Bronze) |  String.IsEqual(Skin.String(PulseColor),Green) | String.IsEqual(Skin.String(PulseColor),cyan) | String.IsEqual(Skin.String(PulseColor),Pink) | String.IsEqual(Skin.String(PulseColor),Red) | String.IsEqual(Skin.String(PulseColor),Colors)">special://skin/extras/neropulse/light_pulse_blk.png</value>
		<value>special://skin/extras/neropulse/light_pulse_blk.png</value>
	</variable>
    <!-- Pulse Includes -->
	<include name="PULSE">
		<!-- Fade pulse when in widgets -->
		<control type="group" description="Static Pulse">
			<include>HomeMenu_Submenu_HiddenAnimation</include>
			<visible>Skin.HasSetting(HomeMenuAnimation)</visible>
			<!-- DARK PULSE -->
			<top>40</top>
			<control type="image">
				<height>720</height>
				<width>1280</width>
				<texture>$VAR[darkpulse]</texture>
			</control>
			<!-- LIGHT PULSE -->
			<control type="image">
				<height>720</height>
				<width>1280</width>
				<texture>$VAR[lightpulse]</texture>
			</control>
			<!-- DARKSPOT -->
			<control type="image">
				<visible>!Skin.HasSetting(ClassicHomeMenu)</visible>
				<left>-480</left>
				<height>720</height>
				<width>1280</width>
				<texture colordiffuse="$VAR[darkpulsediffuse]">windows/bg/darkspot.png</texture>
				<align>center</align>
				<aligny>center</aligny>
			</control>
			<!-- DARKSPOT - CLASSIC MENU -->
			<control type="image">
				<visible>Skin.HasSetting(ClassicHomeMenu)</visible>
				<left>0</left>
				<height>720</height>
				<width>1280</width>
				<texture colordiffuse="$VAR[darkpulsediffuse]">windows/bg/darkspot.png</texture>
				<align>center</align>
				<aligny>center</aligny>
			</control>
		</control>
		<control type="group" description="Animated Pulse">
		    <!-- Fade pulse when in widgets -->
			<include>HomeMenu_Submenu_HiddenAnimation</include>
			<visible>!Skin.HasSetting(HomeMenuAnimation)</visible>
			<!-- DARK PULSE -->
			<top>40</top>
			<control type="image">
				<height>720</height>
				<width>3280</width>
				<texture>$VAR[darkpulse]</texture>
				<animation type="Conditional" condition="true" loop="true" reversible="false">
					<effect type="slide" start="-2000,0" end="0,0" time="30350" />
					<effect type="slide" start="0,0" end="-2000,0" time="30350" delay="30350"/>
				</animation>
			</control>
			<!-- LIGHT PULSE -->
			<control type="image">
				<height>720</height>
				<width>3280</width>
				<texture>$VAR[lightpulse]</texture>
				<animation type="Conditional" condition="true" loop="true" reversible="false">
					<effect type="slide" start="0,0" end="-2000,0" time="30350" />
					<effect type="slide" start="0,0" end="2000,0" time="30350" delay="30350"/>
				</animation>
			</control>
			<!-- DARKSPOT -->
			<control type="image">
				<visible>!Skin.HasSetting(ClassicHomeMenu)</visible>
				<left>-800</left>
				<height>720</height>
				<width>1920</width>
				<texture colordiffuse="$VAR[darkpulsediffuse]">windows/bg/darkspot.png</texture>
				<align>center</align>
				<aligny>center</aligny>
				<animation type="Conditional" condition="true" loop="true" reversible="false">
					<effect type="fade" start="30" end="94" time="5000"/>
					<effect type="fade" start="94" end="30" time="5000" delay="30350"/>
				</animation>
			</control>
			<!-- DARKSPOT - CLASSIC MENU -->
			<control type="image">
				<visible>Skin.HasSetting(ClassicHomeMenu)</visible>
				<left>-333</left>
				<height>720</height>
				<width>1920</width>
				<texture colordiffuse="$VAR[darkpulsediffuse]">windows/bg/darkspot.png</texture>
				<align>center</align>
				<aligny>center</aligny>
				<animation type="Conditional" condition="true" loop="true" reversible="false">
					<effect type="fade" start="30" end="94" time="5000"/>
					<effect type="fade" start="94" end="30" time="5000" delay="30350"/>
				</animation>
			</control>
		</control>
	</include>
	<!-- Pulse Radio Button with Swatch -->
	<include name="SettingsPulseRadioButton">
		<description>Pulse Radio Button with Swatch offset</description>
		<width>784</width>
		<height>50</height>
		<font>FontSize_22</font>
		<texturefocus border="1">windows/settings/settings_right_fo.png</texturefocus>
		<texturenofocus></texturenofocus>
		<textoffsetx>50</textoffsetx>
		<textwidth>700</textwidth>
		<radioposx>754</radioposx>
	</include>
	<!-- Pulse Color Swatch -->
	<include name="PulseColorSwatch">
		<param name="SwatchColor" />
		<definition>
			<control type="image">
				<left>10</left>
				<top>14</top>
				<width>26</width>
				<height>24</height>
				<texture colordiffuse="$PARAM[SwatchColor]">windows/bg/white.png</texture>
			</control>
		</definition>
	</include>
	
