<?xml version="1.0" encoding="UTF-8"?>
<addon
  id="skin.pm3-hd.extended"
  version="1.0.8"
  name="PM3-HD.Extended"
  provider-name="Knuckles">
  <requires>
    <import addon="xbmc.gui" version="5.17.0"/>
	<import addon="script.skinshortcuts" version="2.0.3"/>
  </requires>
  <extension
    point="xbmc.gui.skin"
    defaultthemename="Textures.xbt"
    debugging="false"
    effectslowdown="1.0">
    <res width="1280" height="720" aspect="16:9" default="true" folder="720p" />
  </extension>
  <extension point="xbmc.addon.metadata">
    <assets>
	    <icon>resources/icon.png</icon>
	    <fanart>resources/fanart.jpg</fanart>
	    <screenshot>_screenshots/screenshot01.jpg</screenshot>
	    <screenshot>_screenshots/screenshot02.jpg</screenshot>
	    <screenshot>_screenshots/screenshot03.jpg</screenshot>
    </assets>
	<summary lang="en">A Retro Skin For All Devices</summary>
    <description lang="en">PM3-HD Updated To Omega And Reworked Throughout, Also Now Includes Main Menu And Submenu Shortcuts Options.&#10;Full Credit To Original Creaters Jezz_X,Team XBMC,TigerbotHesh,qqbenq</description>
    <platform>all</platform>
  </extension>
</addon>
